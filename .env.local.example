# Vercel / 로컬: PostgreSQL 연결 문자열 (서버 API 전용 — NEXT_PUBLIC 붙이지 마세요)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres

# 선택: 브라우저 Realtime — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# 새 키: API Keys 탭의 "Publishable key" (sb_publishable_...)
# 예전 대시보드: Legacy → anon JWT (eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
